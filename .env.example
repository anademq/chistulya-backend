# ═══════════════════════════════════════════════════════════════════════════════
# Chistulya - Production Environment
# ═══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Чистюля"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.xn--h1agrefu5d.xn--p1ai
APP_FRONTEND_URL="https://чистуля.рф"
APP_TIMEZONE=Europe/Moscow

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file

GRAPHIQL_ENABLED=true

BCRYPT_ROUNDS=12

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=chistulya
DB_USERNAME=chistulya
DB_PASSWORD=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.xn--h1agrefu5d.xn--p1ai

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_STORE=redis

# ── Queue ─────────────────────────────────────────────────────────────────────
QUEUE_CONNECTION=redis

# ── Broadcasting (Laravel Reverb) ─────────────────────────────────────────────
BROADCAST_CONNECTION=reverb

# Internal: used by app/queue containers to connect to the reverb container
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

# Frontend clients connect through nginx (wss://api.чистуля.рф/app/KEY)
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=api.xn--h1agrefu5d.xn--p1ai
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

# ── Filesystem ─────────────────────────────────────────────────────
FILESYSTEM_DISK=s3

# AWS_ vars must match MINIO_ROOT_ credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=chistulya-media
AWS_ENDPOINT=http://minio:9000
AWS_URL=https://storage.xn--h1agrefu5d.xn--p1ai
AWS_USE_PATH_STYLE_ENDPOINT=true

# ── Mail (SMTP) ───────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=host.docker.internal
MAIL_PORT=25
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_VERIFY_PEER=false
MAIL_FROM_ADDRESS="no-reply@чистуля.рф"
MAIL_FROM_NAME="ЧИСТУЛЯ.РФ"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=

